# =============================================================================
# MusicPro School — variabili ambiente monorepo
# Copia in .env e compila i valori. NON committare .env.
# =============================================================================

# --- Supabase Auth (web — Next.js) ---
# Dashboard URL per redirect post-conferma email (opzionale, configurare anche in Supabase Dashboard)
# Authentication → URL Configuration → Site URL: http://localhost:3000
# Redirect URLs: http://localhost:3000/**
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- Supabase Auth (mobile — Expo) ---
# Stesso progetto Supabase del web. In Supabase Dashboard aggiungi redirect se usi deep link.
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- Supabase (server-side, solo backend / script) ---
# Service role bypassa RLS — usare solo in Edge Functions / script di migrazione, mai nel client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Note autenticazione ---
# - Auth: email + password (sostituisce i magic link GAS).
# - Al primo login/signup, auth.users.email viene collegato a members.email via migration 004_auth_hooks.sql.
# - L'utente deve usare la stessa email presente in anagrafica; altrimenti il login fallisce con messaggio esplicito.
# - Per utenti migrati senza match email: collegare manualmente con UPDATE members SET user_id = '<auth-uuid>' WHERE email = '...';
# - Conferma email: in Supabase Dashboard → Authentication → Providers → Email, abilitare/disabilitare "Confirm email" secondo ambiente.

# --- Stripe (placeholder) ---
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CURRENCY=eur
STRIPE_MODE=test
STRIPE_SECRET_KEY_TEST=sk_test_...
STRIPE_SECRET_KEY_LIVE=sk_live_...
STRIPE_RETURN_URL=https://iscrizione.musicproeventi.it/

# --- Iscrizione backend (deploy-iscrizione.js) ---
# ISCRIZIONE_BACKEND=gas|supabase
# ISCRIZIONE_SUPABASE_API_URL=https://your-app.vercel.app/api/iscrizione
