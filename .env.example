# Copia in .env e compila i valori. NON committare .env

# --- Iscrizione (sottodominio iscrizione.musicproeventi.it) ---
# deploy: npm run deploy:iscrizione
FTP_HOST_ISCRIZIONE=iscrizione.musicproeventi.it
ISCRIZIONE_FTP_USER=mauro@iscrizione.musicproeventi.it
FTP_PASS_ISCRIZIONE=
ISCRIZIONE_FTP_REMOTE_PATH=/

# Backend: gas (Google Apps Script) | supabase (Next.js + Supabase)
ISCRIZIONE_BACKEND=supabase
ISCRIZIONE_SUPABASE_API_URL=https://school.musicproeventi.it/api/iscrizione

# Fallback GAS se ISCRIZIONE_BACKEND=gas
GAS_ISCRIZIONE_URL=https://script.google.com/macros/s/DEPLOYMENT_ID/exec

# Stripe iscrizione (anche su Vercel → progetto school)
STRIPE_MODE=live
STRIPE_SECRET_KEY_TEST=sk_test_...
STRIPE_SECRET_KEY_LIVE=sk_live_...
STRIPE_WEBHOOK_TOKEN=
STRIPE_RETURN_URL=https://iscrizione.musicproeventi.it/
STRIPE_CURRENCY=eur

# --- School admin (sottodominio school.musicproeventi.it — Next.js su Vercel) ---
SCHOOL_PUBLIC_URL=https://school.musicproeventi.it
FTP_HOST_SCHOOL=school.musicproeventi.it
SCHOOL_FTP_USER=
FTP_PASS_SCHOOL=
SCHOOL_FTP_REMOTE_PATH=/

# --- Supabase MusicProSchool ---
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
GOOGLE_SERVICE_ACCOUNT_JSON=/path/to/service-account.json

# Test iscrizione API: node scripts/test-iscrizione-enrollment.mjs
